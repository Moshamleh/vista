{
  "name": "@vista/admin-control-center",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "React Admin Control Center for the Vista AI Authority Engine.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
